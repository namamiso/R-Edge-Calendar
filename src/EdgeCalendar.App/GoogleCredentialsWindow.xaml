<Window x:Class="EdgeCalendar.App.GoogleCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Google OAuth Settings"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="This build does not include the official OAuth Client ID. Enter a Google Desktop OAuth Client ID for development."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   Foreground="#444444" />

        <TextBlock Text="Google Client ID" Foreground="#666666" />
        <TextBox x:Name="ClientIdBox" Margin="0,4,0,12" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="88" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="Save" Width="88" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
