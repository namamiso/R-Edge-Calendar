<Window x:Class="EdgeCalendar.App.GoogleCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Google API 設定"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="16">
        <TextBlock Text="Google Client ID" Foreground="#666666" />
        <TextBox x:Name="ClientIdBox" Margin="0,4,0,12" />

        <TextBlock Text="Google Client Secret" Foreground="#666666" />
        <PasswordBox x:Name="ClientSecretBox" Margin="0,4,0,12" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="88" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="保存" Width="88" Click="OnSave" />
        </StackPanel>
    </StackPanel>
</Window>
