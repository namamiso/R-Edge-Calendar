<Window x:Class="EdgeCalendar.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="780"
        Opacity="0"
        FontFamily="Yu Gothic UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F3F3F3" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#F9F9F9" />
        <SolidColorBrush x:Key="InkBrush" Color="#1F1F1F" />
        <SolidColorBrush x:Key="MutedBrush" Color="#616161" />
        <SolidColorBrush x:Key="AccentBrush" Color="#0067C0" />
        <SolidColorBrush x:Key="RedDayBrush" Color="#C42B1C" />
        <SolidColorBrush x:Key="LineBrush" Color="#E5E5E5" />

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F5F5F5" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EDEDED" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CalendarDayButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="MinHeight" Value="92" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CellRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CellRoot" Property="Background" Value="#F8FBFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="#EAF3FF" />
                    <Setter Property="BorderBrush" Value="#B9D7F7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="18"
            Background="{StaticResource PanelBrush}"
            BorderBrush="#DADADA"
            BorderThickness="1"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.18" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False">
                <StackPanel>
                    <TextBlock Text="EdgeCalendar"
                               Foreground="{StaticResource InkBrush}"
                               FontSize="24"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedDateLabel}"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="12"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Top">
                    <Button Content="更新" Width="70" Margin="0,0,8,0" Click="OnSyncClick" />
                    <Button Content="設定" Width="70" Click="OnCalendarsClick" />
                </StackPanel>
            </DockPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,14,0,0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Padding="0"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="14,12,14,12">
                                <Button Content="‹"
                                        Width="42"
                                        Height="36"
                                        FontSize="24"
                                        Padding="0"
                                        Click="OnPreviousMonthClick" />
                                <Button Content="›"
                                        DockPanel.Dock="Right"
                                        Width="42"
                                        Height="36"
                                        FontSize="24"
                                        Padding="0"
                                        Click="OnNextMonthClick" />
                                <TextBlock Text="{Binding MonthTitle}"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </DockPanel>

                            <UniformGrid Grid.Row="1" Columns="7" Background="{StaticResource SubtleSurfaceBrush}">
                                <TextBlock Text="日" HorizontalAlignment="Center" Foreground="{StaticResource RedDayBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="月" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="火" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="水" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="木" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="金" HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                                <TextBlock Text="土" HorizontalAlignment="Center" Foreground="{StaticResource RedDayBrush}" FontWeight="SemiBold" FontSize="13" Padding="0,6" />
                            </UniformGrid>

                            <ItemsControl Grid.Row="2" ItemsSource="{Binding CalendarDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" Rows="6" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource CalendarDayButtonStyle}"
                                                ToolTip="{Binding HolidayName}"
                                                CommandParameter="{Binding Date}"
                                                Click="OnCalendarDayClick">
                                            <StackPanel>
                                                <Grid Height="28">
                                                    <Border Width="30" Height="30" CornerRadius="15" HorizontalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter Property="Background" Value="#176DCE" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <TextBlock Text="{Binding DayText}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="18"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                        <Setter Property="Foreground" Value="#A7A79F" />
                                                                        <Setter Property="FontWeight" Value="Normal" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRedDay}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource RedDayBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                                        <Setter Property="Foreground" Value="#FFFFFF" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>

                                                <ItemsControl ItemsSource="{Binding Events}" Margin="0,3,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="12" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Width="7" Height="7" Fill="{Binding ColorHex}" VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="1"
                                                                           FontSize="11.5"
                                                                           Foreground="{StaticResource InkBrush}"
                                                                           Text="{Binding DisplayText}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           TextWrapping="NoWrap"
                                                                           LineHeight="14" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Grid Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="選択日の予定"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Events.Count, StringFormat={}{0}件}"
                                       DockPanel.Dock="Right"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Bottom" />
                        </DockPanel>

                        <ListView x:Name="EventsList"
                                  Grid.Row="1"
                                  ItemsSource="{Binding Events}"
                                  SelectionChanged="OnEventSelectionChanged"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource LineBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="4"
                                                    CornerRadius="2"
                                                    Background="{Binding ColorHex}"
                                                    Margin="0,1,8,1" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding TimeLabel}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Title}"
                                                       Foreground="{StaticResource InkBrush}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button x:Name="AddButton" Content="追加" Width="74" Margin="0,0,8,0" Click="OnAddClick" />
                <Button x:Name="EditButton" Content="編集" Width="74" Margin="0,0,8,0" Click="OnEditClick" />
                <Button x:Name="DeleteButton" Content="削除" Width="74" Click="OnDeleteClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
