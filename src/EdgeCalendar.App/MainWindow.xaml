<Window x:Class="EdgeCalendar.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Width="560"
        Opacity="0">
    <Border CornerRadius="16" Background="#CC1E1E1E" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel LastChildFill="False">
                <TextBlock Text="EdgeCalendar" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="カレンダー" Width="88" Margin="0,0,8,0" Click="OnCalendarsClick" />
                    <Button Content="同期" Width="72" Click="OnSyncClick" />
                </StackPanel>
            </DockPanel>

            <Grid Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Calendar x:Name="CalendarControl"
                          SelectedDatesChanged="OnSelectedDateChanged" />

                <ListView x:Name="EventsList"
                          Grid.Column="2"
                          ItemsSource="{Binding Events}"
                          SelectionChanged="OnEventSelectionChanged"
                          Background="#1A1A1A"
                          BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="8,6">
                                <TextBlock Text="{Binding TimeLabel}" Foreground="#B0B0B0" FontSize="12" />
                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="AddButton" Content="追加" Width="72" Margin="0,0,8,0" Click="OnAddClick" />
                <Button x:Name="EditButton" Content="編集" Width="72" Margin="0,0,8,0" Click="OnEditClick" />
                <Button x:Name="DeleteButton" Content="削除" Width="72" Click="OnDeleteClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
