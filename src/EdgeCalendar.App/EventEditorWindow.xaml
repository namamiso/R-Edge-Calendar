<Window x:Class="EdgeCalendar.App.EventEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="予定編集"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="16">
        <TextBlock Text="タイトル" Foreground="#B0B0B0" />
        <TextBox x:Name="TitleBox" Margin="0,4,0,12" />

        <TextBlock Text="カレンダー" Foreground="#B0B0B0" />
        <ComboBox x:Name="CalendarBox" Margin="0,4,0,12" DisplayMemberPath="Summary" />

        <TextBlock Text="開始" Foreground="#B0B0B0" />
        <Grid Margin="0,4,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="StartDatePicker" />
            <TextBox x:Name="StartTimeBox" Grid.Column="2" />
        </Grid>

        <TextBlock Text="終了" Foreground="#B0B0B0" />
        <Grid Margin="0,4,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <DatePicker x:Name="EndDatePicker" />
            <TextBox x:Name="EndTimeBox" Grid.Column="2" />
        </Grid>

        <CheckBox x:Name="AllDayCheckBox" Content="終日" Margin="0,0,0,12" Checked="OnAllDayChanged" Unchecked="OnAllDayChanged" />

        <TextBlock Text="場所" Foreground="#B0B0B0" />
        <TextBox x:Name="LocationBox" Margin="0,4,0,12" />

        <TextBlock Text="メモ" Foreground="#B0B0B0" />
        <TextBox x:Name="NotesBox" Margin="0,4,0,12" Height="80" AcceptsReturn="True" TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="80" Margin="0,0,8,0" Click="OnCancel" />
            <Button Content="OK" Width="80" Click="OnOk" />
        </StackPanel>
    </StackPanel>
</Window>
